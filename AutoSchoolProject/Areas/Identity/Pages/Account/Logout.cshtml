@page
@model LogoutModel
@{
    ViewData["Title"] = "Изход";
}

<header class="card p-4 shadow-sm">
    <h1 class="h3 mb-3">@ViewData["Title"]</h1>
    @if (User.Identity?.IsAuthenticated ?? false)
    {
        <p class="text-muted">Натисни бутона по-долу, за да излезеш от профила си.</p>
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Page("/", new { area = "" })" method="post">
            <button type="submit" class="btn btn-danger">Изход</button>
        </form>
    }
    else
    {
        <p>Излезе успешно от приложението.</p>
    }
</header>
