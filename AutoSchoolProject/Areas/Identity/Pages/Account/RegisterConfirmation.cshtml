@page
@model AutoSchoolProject.Areas.Identity.Pages.Account.RegisterConfirmationModel
@{
    ViewData["Title"] = "Потвърден имейл";
}

<div class="card shadow-sm p-4">
    <h2 class="h3 mb-3">Имейлът е потвърден успешно</h2>
    <p>Профилът с имейл <strong>@Model.Email</strong> вече е активен.</p>
    <p class="mb-4">Можеш веднага да влезеш и да подадеш заявка за записване.</p>

    <a asp-page="/Account/Login" class="btn btn-primary">Към вход</a>
</div>
