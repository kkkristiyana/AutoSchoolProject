@page
@model LoginModel
@{
    ViewData["Title"] = "Вход";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-grid">
            <section class="auth-panel">
                <div class="auth-brand">
                    <img src="~/images/logo.jpeg" alt="Лого" />
                    <div>
                        <div class="fw-bold text-uppercase">Автошкола</div>
                        <div class="small">Система за управление</div>
                    </div>
                </div>

                <div class="auth-title">Вход</div>
                <p class="auth-subtitle">Влез в профила си, за да управляваш графика, заявките и часовете си.</p>

                <form id="account" method="post" class="auth-form">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="Input.Email" class="form-label">Имейл</label>
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Input.Password" class="form-label">Парола</label>
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="Въведи парола" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mt-4">
                        <div class="form-check">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            <label class="form-check-label" asp-for="Input.RememberMe">Запомни ме</label>
                        </div>

                        <button id="login-submit" type="submit" class="auth-primary-btn">Вход</button>
                    </div>
                </form>
            </section>

            <aside class="auth-side">
                <div class="auth-tab">Регистрация</div>
                <h2 class="h3 fw-bold text-uppercase mb-3">Нямаш профил?</h2>
                <p class="mb-4">Създай си акаунт и използвай същите данни за вход през целия процес на записване и обучение.</p>

                <ul class="mb-4">
                    <li>Един и същ имейл за регистрация и записване</li>
                    <li>Бърз достъп до график, практика и резултати</li>
                    <li>Проследяване на одобрението от администратора</li>
                </ul>

                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-nav-accent align-self-start">Създай профил</a>
            </aside>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
