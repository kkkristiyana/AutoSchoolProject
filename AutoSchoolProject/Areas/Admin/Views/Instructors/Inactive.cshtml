@model List<InstructorRowViewModel>
@{
    ViewData["Title"] = "Инструктори извън длъжност";
}

<h2 class="mb-3">Инструктори извън длъжност</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex gap-2 flex-wrap mb-3">
    <a class="btn btn-outline-primary"
       asp-area="Admin" asp-controller="Instructors" asp-action="Index">Активни инструктори</a>
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
       class="btn btn-outline-secondary">← Назад към админ таблото</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Все още няма инструктори в този списък.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Име</th>
                <th>Имейл</th>
                <th>Телефон</th>
                <th>Категория</th>
                <th>Одобрени (предстоящи)</th>
                <th>Работи в момента</th>
                <th class="text-end">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var i in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            @if (!string.IsNullOrWhiteSpace(i.ProfileImagePath))
                            {
                                <img src="@i.ProfileImagePath" style="width:32px;height:32px;border-radius:50%;object-fit:cover;" />
                            }
                            <span>@i.FullName</span>
                        </div>
                    </td>
                    <td>@i.Email</td>
                    <td>@i.PhoneNumber</td>
                    <td>@i.CourseName</td>
                    <td>@i.UpcomingApprovedLessons</td>
                    <td>
                        <span class="badge bg-secondary">Не</span>
                    </td>
                    <td class="text-end">
                        <form asp-area="Admin" asp-controller="Instructors" asp-action="MarkAsWorking" asp-route-id="@i.Id"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                Върни на длъжност
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
