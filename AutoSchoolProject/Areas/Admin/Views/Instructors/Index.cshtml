@model List<InstructorRowViewModel>
@{
    ViewData["Title"] = "Активни инструктори";
}

<h2 class="mb-3">Активни инструктори</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex gap-2 flex-wrap mb-3">
    <a class="btn btn-outline-primary"
       asp-area="Admin" asp-controller="Instructors" asp-action="Inactive">Извън длъжност</a>
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
       class="btn btn-outline-secondary">← Назад към админ таблото</a>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Име</th>
            <th>Имейл</th>
            <th>Телефон</th>
            <th>Категория</th>
            <th>Одобрени (предстоящи)</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var i in Model)
        {
            <tr>
                <td>
                    <div class="d-flex align-items-center gap-2">
                        @if (!string.IsNullOrWhiteSpace(i.ProfileImagePath))
                        {
                            <img src="@i.ProfileImagePath" style="width:32px;height:32px;border-radius:50%;object-fit:cover;" />
                        }
                        <span>@i.FullName</span>
                    </div>
                </td>
                <td>@i.Email</td>
                <td>@i.PhoneNumber</td>
                <td>@i.CourseName</td>
                <td>@i.UpcomingApprovedLessons</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary"
                       asp-area="Admin" asp-controller="Instructors" asp-action="Edit" asp-route-id="@i.Id">Редакция</a>

                    <a class="btn btn-sm btn-primary"
                       asp-area="Admin" asp-controller="InstructorPanel" asp-action="Profile" asp-route-instructorId="@i.Id">Панел на инструктора</a>

                    <form asp-area="Admin" asp-controller="Instructors" asp-action="MarkAsNotWorking" asp-route-id="@i.Id"
                          method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            Не е на длъжност
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
