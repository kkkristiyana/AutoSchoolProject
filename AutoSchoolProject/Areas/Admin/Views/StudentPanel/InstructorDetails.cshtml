@model AutoSchoolProject.ViewModels.Student.InstructorDetailsViewModel

@{
    ViewData["Title"] = "Детайли за инструктор (Admin Student Panel)";
    var hasProfile = !string.IsNullOrWhiteSpace(Model.ProfileImagePath);
    var hasCar = !string.IsNullOrWhiteSpace(Model.CarImagePath);
    int studentId = ViewBag.StudentId is int v ? v : 0;
}

<partial name="_StudentPanelNav" />

<h3 class="mb-3">@Model.FullName</h3>

<div class="card">
    <div class="card-body">
        <div class="d-flex gap-3 align-items-start mb-3">
            @if (hasProfile)
            {
                <img src="@Model.ProfileImagePath" alt="Профилна" style="width:88px;height:88px;object-fit:cover;border-radius:50%;" />
            }
            <div>
                <p class="mb-1"><strong>Автошкола:</strong> @Model.SchoolName</p>
                <p class="mb-1"><strong>Имейл:</strong> @Model.Email</p>
                <p class="mb-1"><strong>Телефон:</strong> @Model.PhoneNumber</p>
                @if (!string.IsNullOrWhiteSpace(Model.CarModel))
                {
                    <p class="mb-0"><strong>Кола:</strong> @Model.CarModel</p>
                }
            </div>
        </div>

        @if (hasCar)
        {
            <div class="mb-3">
                <div class="fw-bold mb-1">Кола</div>
                <img src="@Model.CarImagePath" alt="Кола" style="max-width:100%;height:auto;border-radius:12px;" />
            </div>
        }

        <div class="mt-3">
            <a class="btn btn-success" asp-area="Admin" asp-controller="StudentPanel" asp-action="BookLesson" asp-route-studentId="@studentId" asp-route-instructorId="@Model.InstructorId">
                Запази час
            </a>

            <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="StudentPanel" asp-action="Instructors" asp-route-studentId="@studentId">
                Назад
            </a>
        </div>
    </div>
</div>
