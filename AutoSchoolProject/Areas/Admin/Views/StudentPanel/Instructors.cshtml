@model List<AutoSchoolProject.ViewModels.Student.InstructorListViewModel>

@{
    ViewData["Title"] = "Инструктори (Admin Student Panel)";
    int studentId = ViewBag.StudentId is int v ? v : 0;
}

<partial name="_StudentPanelNav" />

<h3 class="mb-3">🧑‍🏫 Инструктори</h3>

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Няма налични инструктори за категорията на този курсист.</div>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Име</th>
                <th>Категория</th>
                <th>Телефон</th>
                <th>Имейл</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var i in Model)
            {
                <tr>
                    <td>@i.FullName</td>
                    <td>@i.CourseName</td>
                    <td>@i.PhoneNumber</td>
                    <td>@i.Email</td>
                    <td class="text-end">
                        <a class="btn btn-sm btn-outline-primary"
                           asp-area="Admin" asp-controller="StudentPanel" asp-action="InstructorDetails" asp-route-studentId="@studentId" asp-route-id="@i.Id">
                            Детайли
                        </a>
                        <a class="btn btn-sm btn-success"
                           asp-area="Admin" asp-controller="StudentPanel" asp-action="BookLesson" asp-route-studentId="@studentId" asp-route-instructorId="@i.Id">
                            Запази час
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
