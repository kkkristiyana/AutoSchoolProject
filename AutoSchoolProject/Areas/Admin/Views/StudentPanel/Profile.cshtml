@model AutoSchoolProject.ViewModels.Student.StudentProfileViewModel

@{
    ViewData["Title"] = "Профил";
    var studentId = ViewBag.StudentId is int v ? v : 0;
    var hasImg = !string.IsNullOrWhiteSpace(Model.ProfileImagePath);
}

<partial name="_StudentPanelNav" />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body d-flex gap-3 align-items-center">
        @if (hasImg)
        {
            <img src="@Model.ProfileImagePath" alt="Профилна снимка" style="width:96px;height:96px;object-fit:cover;border-radius:50%;" />
        }
        else
        {
            <div style="width:96px;height:96px;border-radius:50%;background:#e9ecef;display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:700;">
                @(string.IsNullOrWhiteSpace(Model.FullName) ? "?" : Model.FullName.Substring(0, 1).ToUpper())
            </div>
        }

        <div>
            <h4 class="mb-2">@Model.FullName</h4>
            <p class="mb-1"><strong>Имейл:</strong> @Model.Email</p>
            <p class="mb-1"><strong>Телефон:</strong> @Model.PhoneNumber</p>
            <p class="mb-0"><strong>Курс:</strong> @Model.CourseName</p>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.AdminMessage))
{
    <div class="card border-info shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-2">Съобщение от администратора</h5>
            <p class="mb-0">@Model.AdminMessage</p>
        </div>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <h5 class="card-title">Напредък</h5>
        <p class="mb-1">Проведени часове: <strong>@Model.CompletedLessons</strong></p>
        <p class="mb-0">Оставащи часове: <strong>@Model.RemainingLessons</strong></p>
    </div>
</div>

<div class="d-flex flex-wrap gap-2">
    <a asp-area="Admin" asp-controller="StudentPanel" asp-action="EditProfile" asp-route-studentId="@studentId" class="btn btn-primary">Редактирай профила</a>
    <a asp-area="Admin" asp-controller="StudentPanel" asp-action="Instructors" asp-route-studentId="@studentId" class="btn btn-success">Запази час</a>
</div>
