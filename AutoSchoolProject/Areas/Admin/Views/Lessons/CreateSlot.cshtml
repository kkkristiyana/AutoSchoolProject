@model AutoSchoolProject.ViewModels.Admin.CreateAvailableSlotViewModel
@{
    ViewData["Title"] = "Нов свободен слот";
}

<h2 class="mb-3">➕ Нов свободен слот (Практика)</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form asp-area="Admin" asp-controller="Lessons" asp-action="CreateSlot" method="post" class="card shadow-sm p-3">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="InstructorId" class="form-label"></label>
        <select asp-for="InstructorId" asp-items="Model.Instructors" class="form-select">
            <option value="">-- избери инструктор --</option>
        </select>
        <span asp-validation-for="InstructorId" class="text-danger"></span>
    </div>

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="DateTime" class="form-label"></label>
            <input asp-for="DateTime" class="form-control" type="datetime-local" value="@Model.DateTime.ToString("yyyy-MM-ddTHH:mm")" />
            <span asp-validation-for="DateTime" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="DurationMinutes" class="form-label"></label>
            <input asp-for="DurationMinutes" class="form-control" />
            <span asp-validation-for="DurationMinutes" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <label asp-for="CourseId" class="form-label"></label>
        <select asp-for="CourseId" asp-items="Model.Courses" class="form-select">
            <option value="">-- важи за всички категории --</option>
        </select>
        <span asp-validation-for="CourseId" class="text-danger"></span>
        <div class="form-text">Ако оставиш празно, слотът ще се показва на всички ученици (без значение категорията).</div>
    </div>

    <div class="mt-3">
        <label asp-for="Note" class="form-label"></label>
        <input asp-for="Note" class="form-control" />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Създай слот</button>
        <a class="btn btn-outline-secondary ms-2" asp-area="Admin" asp-controller="Lessons" asp-action="Index">Назад</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
