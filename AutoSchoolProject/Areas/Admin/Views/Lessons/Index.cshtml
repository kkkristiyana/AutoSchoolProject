@model List<LessonRowViewModel>
@{
    ViewData["Title"] = "Часове";
    var status = (ViewBag.Status as string) ?? "";
}

<h2 class="mb-3">📅 Часове</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-success" asp-area="Admin" asp-controller="Lessons" asp-action="CreateSlot">+ Свободен слот</a>
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">← Dashboard</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <select class="form-select" name="status">
            <option value="" selected="@(status == "")">Всички</option>
            <option value="Available" selected="@(status == "Available")">Available (свободни)</option>
            <option value="Pending" selected="@(status == "Pending")">Pending (заявки)</option>
            <option value="Approved" selected="@(status == "Approved")">Approved</option>
            <option value="Rejected" selected="@(status == "Rejected")">Rejected</option>
            <option value="Cancelled" selected="@(status == "Cancelled")">Cancelled</option>
        </select>
    </div>
    <div class="col-md-2">
        <button class="btn btn-primary w-100" type="submit">Филтър</button>
    </div>
</form>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Дата</th>
            <th>Ученик</th>
            <th>Инструктор</th>
            <th>Статус</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var l in Model)
        {
            <tr>
                <td>@l.DateTime.ToString("dd.MM.yyyy HH:mm")</td>
                <td>@(string.IsNullOrWhiteSpace(l.StudentName) ? "—" : l.StudentName)</td>
                <td>@(string.IsNullOrWhiteSpace(l.InstructorName) ? "—" : l.InstructorName)</td>
                <td>@l.Status</td>
                <td class="text-end">
                    @if (l.Status == "Pending")
                    {
                        <form asp-area="Admin" asp-controller="Lessons" asp-action="Approve" asp-route-id="@l.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-success">Approve</button>
                        </form>
                        <form asp-area="Admin" asp-controller="Lessons" asp-action="Reject" asp-route-id="@l.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-warning">Reject</button>
                        </form>
                    }

                    @if (l.Status != "Rejected" && l.Status != "Cancelled")
                    {
                        <form asp-area="Admin" asp-controller="Lessons" asp-action="Cancel" asp-route-id="@l.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button class="btn btn-sm btn-danger">Cancel</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
