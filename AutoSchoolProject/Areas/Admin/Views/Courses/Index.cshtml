@model List<AutoSchoolProject.ViewModels.Admin.AdminCourseRowViewModel>
@{
    ViewData["Title"] = "Курсове";
}

<h2 class="mb-3">Курсове и категории</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex gap-2 mb-3">
    <a class="btn btn-primary" asp-area="Admin" asp-controller="Courses" asp-action="Create">+ Нов курс</a>
    <a class="btn btn-outline-secondary" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">← Към таблото</a>
</div>

<table class="table table-striped align-middle">
    <thead>
        <tr>
            <th>Име</th>
            <th>Цена</th>
            <th>Задължителни часове</th>
            <th>Ученици</th>
            <th>Инструктори</th>
            <th class="text-end">Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var c in Model)
        {
            <tr>
                <td>@c.Name</td>
                <td>@c.Price.ToString("F2") лв</td>
                <td>@c.RequiredPracticeLessons</td>
                <td>@c.StudentsCount</td>
                <td>@c.InstructorsCount</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-area="Admin" asp-controller="Courses" asp-action="Edit" asp-route-id="@c.Id">Редакция</a>
                    <a class="btn btn-sm btn-outline-danger" asp-area="Admin" asp-controller="Courses" asp-action="Delete" asp-route-id="@c.Id">Изтрий</a>
                </td>
            </tr>
        }
    </tbody>
</table>
