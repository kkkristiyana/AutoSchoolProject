<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Администрация</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">

    <nav class="navbar navbar-expand-lg" style="background:#123247;">
        <div class="container-fluid">
            <a class="navbar-brand text-white d-flex align-items-center gap-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                <img src="~/images/logo.png" alt="Лого" style="width:36px;height:36px;object-fit:contain;" />
                <span>Администрация</span>
            </a>

            <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
                <li class="nav-item">
                    <a class="btn btn-nav-outline"
                       asp-area=""
                       asp-controller="Home"
                       asp-action="Index">
                        Към сайта
                    </a>
                </li>
                <li class="nav-item">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <form asp-area="Identity"
                              asp-page="/Account/Logout"
                              asp-route-returnUrl="/"
                              method="post">
                            <button type="submit" class="btn btn-nav-accent">
                                Изход
                            </button>
                        </form>
                    }
                </li>
            </ul>
        </div>
    </nav>

    <div class="container mt-4">
        @RenderBody()
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
