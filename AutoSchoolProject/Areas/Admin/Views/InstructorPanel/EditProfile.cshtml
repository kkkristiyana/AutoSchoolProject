@model AutoSchoolProject.ViewModels.Admin.AdminEditInstructorViewModel

@{
    ViewData["Title"] = "Редакция на профил";
}

<partial name="_InstructorPanelNav" />

<form asp-area="Admin" asp-controller="InstructorPanel" asp-action="EditProfile" asp-route-instructorId="@Model.InstructorId"
      method="post" enctype="multipart/form-data" class="card shadow-sm p-3">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Профилна снимка</label>
            <div class="file-picker d-flex align-items-center gap-3 flex-wrap">
                <input asp-for="ProfileImage" type="file" id="adminInstructorProfileImage" class="d-none js-bulgarian-file-input" accept="image/*" />
                <label for="adminInstructorProfileImage" class="btn btn-outline-secondary mb-0">Избери файл</label>
                <span class="small text-muted js-file-name">Няма избран файл</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.CurrentProfileImagePath))
            {
                <img src="@Model.CurrentProfileImagePath" alt="Профилна" class="mt-2" style="width:72px;height:72px;object-fit:cover;border-radius:50%;" />
            }
        </div>
        <div class="col-md-6">
            <label class="form-label">Снимка на колата</label>
            <div class="file-picker d-flex align-items-center gap-3 flex-wrap">
                <input asp-for="CarImage" type="file" id="adminInstructorCarImage" class="d-none js-bulgarian-file-input" accept="image/*" />
                <label for="adminInstructorCarImage" class="btn btn-outline-secondary mb-0">Избери файл</label>
                <span class="small text-muted js-file-name">Няма избран файл</span>
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.CurrentCarImagePath))
            {
                <img src="@Model.CurrentCarImagePath" alt="Кола" class="mt-2" style="width:140px;height:80px;object-fit:cover;border-radius:12px;" />
            }
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="PhoneNumber" class="form-label"></label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>
    </div>

    <div class="row g-3 mt-1">
        <div class="col-md-6">
            <label asp-for="CourseId" class="form-label"></label>
            <select asp-for="CourseId" asp-items="Model.Courses" class="form-select">
                <option value="">-- Избери категория --</option>
            </select>
            <span asp-validation-for="CourseId" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="CarModel" class="form-label"></label>
            <input asp-for="CarModel" class="form-control" />
            <span asp-validation-for="CarModel" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Запази</button>
        <a asp-area="Admin" asp-controller="InstructorPanel" asp-action="Profile" asp-route-instructorId="@Model.InstructorId" class="btn btn-outline-secondary ms-2">Назад</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
