@model AutoSchoolProject.ViewModels.Admin.InstructorPanelCreateSlotViewModel

@{
    ViewData["Title"] = "Нов свободен слот (Admin Instructor Panel)";
    int instructorId = ViewBag.InstructorId is int v ? v : 0;
}

<partial name="_InstructorPanelNav" />

<form asp-area="Admin" asp-controller="InstructorPanel" asp-action="CreateSlot" asp-route-instructorId="@instructorId" method="post" class="card shadow-sm p-3">
    @Html.AntiForgeryToken()

    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="DateTime" class="form-label"></label>
            <input asp-for="DateTime" type="datetime-local" class="form-control" value="@Model.DateTime.ToString("yyyy-MM-ddTHH:mm")" />
            <span asp-validation-for="DateTime" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="DurationMinutes" class="form-label"></label>
            <input asp-for="DurationMinutes" class="form-control" />
            <span asp-validation-for="DurationMinutes" class="text-danger"></span>
        </div>
    </div>

    <div class="mt-3">
        <label asp-for="CourseId" class="form-label"></label>
        <select asp-for="CourseId" asp-items="Model.Courses" class="form-select">
            <option value="">-- важи за всички категории --</option>
        </select>
        <span asp-validation-for="CourseId" class="text-danger"></span>
    </div>

    <div class="mt-3">
        <label asp-for="Note" class="form-label"></label>
        <input asp-for="Note" class="form-control" />
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Създай слот</button>
        <a class="btn btn-outline-secondary ms-2" asp-area="Admin" asp-controller="InstructorPanel" asp-action="Lessons" asp-route-instructorId="@instructorId">Назад</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
