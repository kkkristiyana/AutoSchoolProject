@model AutoSchoolProject.ViewModels.Admin.InstructorPanelProfileViewModel
@{
    ViewData["Title"] = "Профил";
}

<partial name="_InstructorPanelNav" />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex gap-3 align-items-start">
                @if (!string.IsNullOrWhiteSpace(Model.ProfileImagePath))
                {
                    <img src="@Model.ProfileImagePath" alt="Профилна снимка" style="width:96px;height:96px;object-fit:cover;border-radius:50%;" />
                }
                else
                {
                    <div style="width:96px;height:96px;border-radius:50%;background:#e9ecef;display:flex;align-items:center;justify-content:center;font-size:32px;font-weight:700;">
                        @(string.IsNullOrWhiteSpace(Model.FullName) ? "?" : Model.FullName.Substring(0, 1).ToUpper())
                    </div>
                }

                <div>
                    <h4 class="mb-2">@Model.FullName</h4>
                    <p class="mb-1"><strong>Имейл:</strong> @Model.Email</p>
                    <p class="mb-1"><strong>Телефон:</strong> @Model.PhoneNumber</p>
                    <p class="mb-1"><strong>Категория:</strong> @Model.CourseName</p>
                    <p class="mb-0"><strong>Превозно средство:</strong> @(string.IsNullOrWhiteSpace(Model.CarModel) ? "—" : Model.CarModel)</p>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h5 class="card-title">Статистика</h5>
                <p class="mb-2">Чакащи заявки: <strong>@Model.PendingLessonsCount</strong></p>
                <p class="mb-2">Одобрени предстоящи: <strong>@Model.UpcomingApprovedLessonsCount</strong></p>
                <p class="mb-0">Проведени часове: <strong>@Model.CompletedLessonsCount</strong></p>
            </div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.CarImagePath))
{
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h5 class="card-title mb-3">Снимка на превозното средство</h5>
            <img src="@Model.CarImagePath" alt="Снимка на колата" style="max-width:100%;max-height:280px;object-fit:cover;border-radius:12px;" />
        </div>
    </div>
}

<div class="mt-3 d-flex flex-wrap gap-2">
    <a asp-area="Admin" asp-controller="InstructorPanel" asp-action="EditProfile" asp-route-instructorId="@Model.InstructorId" class="btn btn-primary">Редактирай профила</a>
    <a asp-area="Admin" asp-controller="InstructorPanel" asp-action="Lessons" asp-route-instructorId="@Model.InstructorId" class="btn btn-success">Виж часовете</a>
</div>
