@model AutoSchoolProject.ViewModels.Admin.InstructorPanelLessonsViewModel
@{
    ViewData["Title"] = "Часове";
    int instructorId = ViewBag.InstructorId is int v ? v : 0;
    string StatusBg(string? status) => status switch
    {
        "Available" => "Свободен слот",
        "Pending" => "Изчаква одобрение",
        "Approved" => "Одобрен",
        "Rejected" => "Отказан",
        "Cancelled" => "Отменен",
        _ => status ?? "—"
    };
}

<partial name="_InstructorPanelNav" />

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card shadow-sm p-3 mb-3">
    <form method="get" asp-area="Admin" asp-controller="InstructorPanel" asp-action="Lessons" asp-route-instructorId="@instructorId" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Филтър по статус</label>
            <select name="status" class="form-select">
                <option value="" selected="@(string.IsNullOrWhiteSpace(Model.Status))">Всички</option>
                <option value="Available" selected="@(Model.Status == "Available")">Свободни слотове</option>
                <option value="Pending" selected="@(Model.Status == "Pending")">Изчакват одобрение</option>
                <option value="Approved" selected="@(Model.Status == "Approved")">Одобрени</option>
                <option value="Rejected" selected="@(Model.Status == "Rejected")">Отказани</option>
                <option value="Cancelled" selected="@(Model.Status == "Cancelled")">Отменени</option>
            </select>
        </div>
        <div class="col-md-3 d-grid">
            <button class="btn btn-primary" type="submit">Приложи</button>
        </div>
    </form>
</div>

@if (!Model.Lessons.Any())
{
    <div class="alert alert-info">Няма намерени часове за този инструктор.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Дата и час</th>
                <th>Курсист</th>
                <th>Категория</th>
                <th>Статус</th>
                <th>Бележка</th>
                <th class="text-end">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var lesson in Model.Lessons)
            {
                <tr>
                    <td>@lesson.DateTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@(string.IsNullOrWhiteSpace(lesson.StudentName) ? "—" : lesson.StudentName)</td>
                    <td>@lesson.CourseName</td>
                    <td>@StatusBg(lesson.Status) @(lesson.Completed ? "• Проведен" : string.Empty)</td>
                    <td>@lesson.Note</td>
                    <td class="text-end">
                        @if (lesson.Status == "Pending")
                        {
                            <form asp-area="Admin" asp-controller="InstructorPanel" asp-action="ApproveLesson" asp-route-instructorId="@instructorId" asp-route-id="@lesson.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-success">Приеми</button>
                            </form>
                            <form asp-area="Admin" asp-controller="InstructorPanel" asp-action="RejectLesson" asp-route-instructorId="@instructorId" asp-route-id="@lesson.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-warning">Откажи</button>
                            </form>
                        }

                        <a class="btn btn-sm btn-outline-primary"
                           asp-area="Admin" asp-controller="InstructorPanel" asp-action="RescheduleLesson" asp-route-instructorId="@instructorId" asp-route-id="@lesson.Id">Пренасрочи</a>

                        @if (!lesson.Completed && lesson.Status != "Cancelled" && lesson.Status != "Rejected" && lesson.Status != "Available")
                        {
                            <a class="btn btn-sm btn-outline-success"
                               asp-area="Admin" asp-controller="InstructorPanel" asp-action="CompleteLesson" asp-route-instructorId="@instructorId" asp-route-id="@lesson.Id">Проведен</a>
                        }

                        @if (lesson.Status != "Cancelled" && lesson.Status != "Rejected")
                        {
                            <form asp-area="Admin" asp-controller="InstructorPanel" asp-action="CancelLesson" asp-route-instructorId="@instructorId" asp-route-id="@lesson.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger">Отмени</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
