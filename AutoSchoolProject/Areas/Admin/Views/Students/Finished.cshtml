@model List<StudentRowViewModel>
@{
    ViewData["Title"] = "Завършили / прекъснали курсисти";
}

<h2 class="mb-3">Завършили / прекъснали курсисти</h2>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="d-flex gap-2 flex-wrap mb-3">
    <a class="btn btn-outline-primary"
       asp-area="Admin" asp-controller="Students" asp-action="Index">Активни курсисти</a>
    <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index"
       class="btn btn-outline-secondary">← Към админ таблото</a>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Все още няма курсисти в този списък.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Име</th>
                <th>Имейл</th>
                <th>Телефон</th>
                <th>Категория</th>
                <th>Часове</th>
                <th>Учи в момента</th>
                <th class="text-end">Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var s in Model)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            @if (!string.IsNullOrWhiteSpace(s.ProfileImagePath))
                            {
                                <img src="@s.ProfileImagePath" style="width:32px;height:32px;border-radius:50%;object-fit:cover;" />
                            }
                            <span>@s.FullName</span>
                        </div>
                    </td>
                    <td>@s.Email</td>
                    <td>@s.PhoneNumber</td>
                    <td>@s.CourseName</td>
                    <td>@s.LessonsCount</td>
                    <td>
                        <span class="badge bg-secondary">Не</span>
                    </td>
                    <td class="text-end">
                        <form asp-area="Admin" asp-controller="Students" asp-action="MarkAsStudying" asp-route-id="@s.Id"
                              method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-success">
                                Върни в активни
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
