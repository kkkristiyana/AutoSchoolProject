@model AutoSchoolProject.ViewModels.Student.InstructorDetailsViewModel

@{
    ViewData["Title"] = "Детайли за инструктор";
}

<h2 class="mb-3">@Model.FullName</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Автошкола:</strong> @Model.SchoolName</p>
        <p><strong>Имейл:</strong> @Model.Email</p>
        <p><strong>Телефон:</strong> @Model.PhoneNumber</p>

        <div class="mt-3">
            <a class="btn btn-success"
               asp-controller="Student" asp-action="BookLesson" asp-route-instructorId="@Model.InstructorId">
                Запази час
            </a>

            <a class="btn btn-outline-secondary"
               asp-controller="Student" asp-action="Instructors">
                Назад
            </a>
        </div>
    </div>
</div>