@model AutoSchoolProject.ViewModels.Student.StudentScheduleViewModel

@{
    ViewData["Title"] = "График";
}

<h2 class="mb-3">График (теория и практика)</h2>

<div class="mb-3">
    <strong>Курс:</strong> @Model.CourseName
</div>

<h4 class="mt-4">Практика</h4>

@if (!Model.Practice.Any())
{
    <div class="alert alert-info">Няма предстоящи часове по практика.</div>
}
else
{
    <table class="table table-hover align-middle">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Инструктор</th>
                <th>Статус</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in Model.Practice)
            {
                <tr>
                    <td>@p.DateTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@p.InstructorName</td>
                    <td>@p.Status</td>
                </tr>
            }
        </tbody>
    </table>
}

<h4 class="mt-4">Теория</h4>

@if (!Model.Theory.Any())
{
    <div class="alert alert-info">Няма предстоящи занятия по теория.</div>
}
else
{
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Дата</th>
                <th>Тема</th>
                <th>Продължителност</th>
                <th>Място</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Theory)
            {
                <tr>
                    <td>@t.DateTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>@t.Topic</td>
                    <td>@t.DurationMinutes мин.</td>
                    <td>@t.Location</td>
                </tr>
            }
        </tbody>
    </table>
    <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="Index">Назад към началната страница</a>
}
