@model AutoSchoolProject.ViewModels.Student.BookLessonViewModel

@{
    ViewData["Title"] = "Запази час";
}

<h2 class="mb-3">Запази час</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<div class="card">
    <div class="card-body">
        <input type="hidden" asp-for="InstructorId" />
        <h4>Инструктор: @Model.InstructorName</h4>

        <form asp-controller="Student" asp-action="BookLesson" method="post">
            <input type="hidden" asp-for="InstructorId" />
            <input type="hidden" asp-for="StudentId" />
            <input type="hidden" asp-for="CourseId" />

            <div class="mb-3">
                <label asp-for="SlotId" class="form-label">Свободни часове</label>
                <select asp-for="SlotId" asp-items="Model.AvailableSlots" class="form-select">
                    <option value="">-- избери --</option>
                </select>
                <span asp-validation-for="SlotId" class="text-danger"></span>
            </div>

            <button class="btn btn-success" type="submit">Запази</button>
            <a class="btn btn-outline-secondary" asp-controller="Student" asp-action="Instructors">Отказ</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
