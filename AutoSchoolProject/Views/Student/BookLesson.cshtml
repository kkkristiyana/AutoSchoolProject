@model AutoSchoolProject.ViewModels.Student.BookLessonViewModel

@{
    ViewData["Title"] = "Запази час";
}

<h2 class="mb-3">📅 Запази час</h2>

<div class="alert alert-secondary">
    Инструктор: <strong>@Model.InstructorName</strong>
</div>

@if (ViewData.ModelState.ErrorCount > 0)
{
    <div class="alert alert-danger">
        @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@err.ErrorMessage</div>
        }
    </div>
}

@if (Model.AvailableSlots == null || !Model.AvailableSlots.Any())
{
    <div class="alert alert-info">
        Няма свободни слотове за записване към момента.
    </div>

    <a class="btn btn-outline-secondary" asp-controller="Student" asp-action="Instructors">← Назад</a>
}
else
{
    <form asp-action="BookLesson" method="post" class="card shadow-sm p-3">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="InstructorId" />
        <input type="hidden" asp-for="StudentId" />
        <input type="hidden" asp-for="CourseId" />

        <div class="mb-3">
            <label asp-for="SlotId" class="form-label">Свободен час</label>
            <select asp-for="SlotId" asp-items="Model.AvailableSlots" class="form-select">
                <option value="">-- Избери свободен час --</option>
            </select>
            <span asp-validation-for="SlotId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">✅ Запази</button>
        <a class="btn btn-outline-secondary ms-2" asp-controller="Student" asp-action="Instructors">Назад</a>
    </form>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}