@{
    var currentArea = ViewContext.RouteData.Values["area"]?.ToString() ?? string.Empty;
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty;
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? string.Empty;

    string NavClass(string area, string controller, string action, string extraClass = "")
    {
        var classes = "nav-link";

        if (!string.IsNullOrWhiteSpace(extraClass))
        {
            classes += " " + extraClass;
        }

        var isActive = string.Equals(currentArea, area, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentController, controller, StringComparison.OrdinalIgnoreCase)
            && string.Equals(currentAction, action, StringComparison.OrdinalIgnoreCase);

        if (isActive)
        {
            classes += " nav-link-active";
        }

        return classes;
    }
}
<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Автошкола</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AutoSchoolProject.styles.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg main-navbar box-shadow-sm">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand d-flex align-items-center gap-3" asp-area="" asp-controller="Home" asp-action="@(User.Identity?.IsAuthenticated == true ? "Index" : "IndexForViewerOnly")">
                    <img src="~/images/logo.jpeg" alt="Лого на автошколата" class="brand-logo" />
                    <span class="brand-text-wrap">
                        <span class="brand-title">Lucky-Cars EOOD</span>
                        <span class="brand-subtitle">АВТОШКОЛА - Система за управление</span>
                    </span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Покажи навигацията">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        @if (User.Identity?.IsAuthenticated != true)
                        {
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "IndexForViewerOnly")" asp-area="" asp-controller="Home" asp-action="IndexForViewerOnly">Начало</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "CoursesInfoOnly")" asp-area="" asp-controller="Home" asp-action="CoursesInfoOnly">Курсове</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "ConditionsViewerOnly")" asp-area="" asp-controller="Home" asp-action="ConditionsViewerOnly">Условия</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "ContactsViewerOnly")" asp-area="" asp-controller="Home" asp-action="ContactsViewerOnly">Контакти</a>
                            </li>
                        }
                        else if (User.IsInRole("Student"))
                        {
                            <li class="nav-item">
                                <a class="@NavClass("", "Student", "Profile")" asp-area="" asp-controller="Student" asp-action="Profile">Профил</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Student", "EditProfile")" asp-area="" asp-controller="Student" asp-action="EditProfile">Редакция на профил</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Student", "Messages")" asp-area="" asp-controller="Student" asp-action="Messages">Съобщения</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Student", "Schedule")" asp-area="" asp-controller="Student" asp-action="Schedule">График</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Student", "MyLessons")" asp-area="" asp-controller="Student" asp-action="MyLessons">Моите часове</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Student", "TestResults")" asp-area="" asp-controller="Student" asp-action="TestResults">Тестове</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Student", "Instructors", "nav-link-accent")" asp-area="" asp-controller="Student" asp-action="Instructors">Запази час</a>
                            </li>
                        }
                        else if (User.IsInRole("Instructor"))
                        {
                            <li class="nav-item">
                                <a class="@NavClass("", "Instructor", "Profile")" asp-area="" asp-controller="Instructor" asp-action="Profile">Профил</a>
                            </li>
                            /*<li class="nav-item">
                                <a class="@NavClass("", "Instructor", "EditProfile")" asp-area="" asp-controller="Instructor" asp-action="EditProfile">Редакция на профил</a>
                            </li>*/
                            <li class="nav-item">
                                <a class="@NavClass("", "Instructor", "Create")" asp-area="" asp-controller="Instructor" asp-action="Create">Създай свободен слот</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Instructor", "PendingLessons")" asp-area="" asp-controller="Instructor" asp-action="PendingLessons">Заявки за час</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Instructor", "Schedule")" asp-area="" asp-controller="Instructor" asp-action="Schedule">График</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Instructor", "MyStudents")" asp-area="" asp-controller="Instructor" asp-action="MyStudents">Курсисти</a>
                            </li>
                        }
                        else if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="@NavClass("Admin", "Dashboard", "Index", "nav-link-accent")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Админ панел</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "Index")" asp-area="" asp-controller="Home" asp-action="Index">Начало</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "Courses")" asp-area="" asp-controller="Home" asp-action="Courses">Курсове</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "Conditions")" asp-area="" asp-controller="Home" asp-action="Conditions">Условия</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "Contacts")" asp-area="" asp-controller="Home" asp-action="Contacts">Контакти</a>
                            </li>
                            <li class="nav-item">
                                <a class="@NavClass("", "Home", "Apply", "nav-link-accent")" asp-area="" asp-controller="Home" asp-action="Apply">Заявка за записване</a>
                            </li>
                        }
                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <div class="page-shell">
        <main role="main" class="container pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="site-footer">
        <div class="container d-flex flex-column flex-md-row justify-content-between gap-2">
            <span>&copy; 2026 Автошкола Lucky-Cars EOOD</span>
            <span>Управление на курсове, графици и практика</span>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
