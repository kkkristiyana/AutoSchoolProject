@using Microsoft.AspNetCore.Identity
@using AutoSchoolProject.Models

@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

<ul class="navbar-nav align-items-lg-center gap-lg-2">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item">
            @if (User.IsInRole("Student"))
            {
                <a class="nav-link nav-user-link" asp-controller="Student" asp-action="Profile">
                    Здравей, @User.Identity?.Name
                </a>
            }
            else if (User.IsInRole("Instructor"))
            {
                <a class="nav-link nav-user-link" asp-controller="Instructor" asp-action="Profile">
                    Здравей, @User.Identity?.Name
                </a>
            }
            else if (User.IsInRole("Admin"))
            {
                <a class="nav-link nav-user-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    Здравей, @User.Identity?.Name
                </a>
            }
            else
            {
                <a class="nav-link nav-user-link" asp-area="Identity" asp-page="/Account/Manage/Index">
                    Здравей, @User.Identity?.Name
                </a>
            }
        </li>
        <li class="nav-item">
            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="/"
                  method="post"
                  class="d-inline">
                <button type="submit" class="btn btn-nav-outline">
                    Изход
                </button>
            </form>
        </li>
    }
    else
    {
        <li class="nav-item">
            <a class="btn btn-nav-outline" asp-area="Identity" asp-page="/Account/Login">Вход</a>
        </li>
        <li class="nav-item">
            <a class="btn btn-nav-accent" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
        </li>
    }
</ul>
