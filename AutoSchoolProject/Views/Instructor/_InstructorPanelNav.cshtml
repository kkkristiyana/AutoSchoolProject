@{
    string instructorName = ViewBag.InstructorName as string ?? "Инструктор";
}

<div class="instructor-nav-shell d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
    <div>
        <div class="small text-muted">Инструкторски панел</div>
        <div class="h4 mb-0 instructor-nav-title">@instructorName</div>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-outline-primary" asp-controller="Instructor" asp-action="Profile">Профил</a>
        <a class="btn btn-outline-primary" asp-controller="Instructor" asp-action="EditProfile">Редакция на профил</a>
        <a class="btn btn-outline-success" asp-controller="Instructor" asp-action="Create">Създай свободен слот</a>
        <a class="btn btn-outline-primary" asp-controller="Instructor" asp-action="PendingLessons">Приеми заявка за час</a>
        <a class="btn btn-outline-primary" asp-controller="Instructor" asp-action="Schedule">Виж график</a>
        <a class="btn btn-outline-primary" asp-controller="Instructor" asp-action="MyStudents">Курсисти</a>
    </div>
</div>

