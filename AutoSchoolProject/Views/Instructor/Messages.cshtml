@model AutoSchoolProject.ViewModels.Common.UserMessagesViewModel

@{
    ViewData["Title"] = Model.Heading;
}

<h2 class="mb-4">@Model.Heading</h2>

@if (!Model.Messages.Any())
{
    <div class="alert alert-info">@Model.EmptyMessage</div>
}
else
{
    foreach (var message in Model.Messages)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                    <div>
                        <h5 class="card-title mb-1">@message.Title</h5>
                        <span class="badge bg-light text-dark">@message.Category</span>
                    </div>
                    <div class="small text-muted">@message.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <p class="mb-0">@message.Body</p>
            </div>
        </div>
    }
}

<a asp-action="Profile" class="btn btn-outline-secondary">Назад към профила</a>
