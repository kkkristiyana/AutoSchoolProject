@model AutoSchoolProject.ViewModels.Instructor.InstructorStudentsViewModel
@{
    ViewData["Title"] = "Курсисти";
}


@if (!Model.Students.Any())
{
    <div class="alert alert-info">Все още няма курсисти, свързани с този инструктор.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Курсист</th>
                        <th>Категория</th>
                        <th>Проведени часове</th>
                        <th>Оставащи часове</th>
                        <th>Последен час</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var student in Model.Students)
                    {
                        <tr>
                            <td>@student.FullName</td>
                            <td>@student.CourseName</td>
                            <td>@student.CompletedLessons</td>
                            <td>@student.RemainingLessons</td>
                            <td>@(student.LastLessonDate.HasValue? student.LastLessonDate.Value.ToString("dd.MM.yyyy HH:mm") : "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
