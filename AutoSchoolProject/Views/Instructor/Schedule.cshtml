@model AutoSchoolProject.ViewModels.Instructor.InstructorScheduleViewModel
@{
    ViewData["Title"] = "График";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="card shadow-sm p-3 mb-3">
    <form method="get" asp-action="Schedule" class="row g-3 align-items-end">
        <div class="col-md-4">
            <label class="form-label">Филтър по статус</label>
            <select name="status" class="form-select">
                <option value="">Всички</option>
                <option value="Available" selected="@(Model.SelectedStatus == "Available")">Свободни слотове</option>
                <option value="Pending" selected="@(Model.SelectedStatus == "Pending")">Изчакват одобрение</option>
                <option value="Approved" selected="@(Model.SelectedStatus == "Approved")">Одобрени</option>
                <option value="Rejected" selected="@(Model.SelectedStatus == "Rejected")">Отказани</option>
                <option value="Cancelled" selected="@(Model.SelectedStatus == "Cancelled")">Отменени</option>
            </select>
        </div>
        <div class="col-md-3 d-flex gap-2">
            <button class="btn btn-primary" type="submit">Приложи</button>
            <a class="btn btn-outline-secondary" asp-action="Schedule">Изчисти</a>
        </div>
    </form>
</div>

@if (!Model.Lessons.Any())
{
    <div class="alert alert-info">Няма намерени часове.</div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0 align-middle">
                <thead>
                    <tr>
                        <th>Дата и час</th>
                        <th>Курсист</th>
                        <th>Категория</th>
                        <th>Статус</th>
                        <th>Бележка</th>
                        <th class="text-end">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var lesson in Model.Lessons)
                    {
                        var canApproveReject = !lesson.Completed && lesson.Status == "Изчаква одобрение" && lesson.DateTime > DateTime.Now;
                        var canReschedule = !lesson.Completed && lesson.DateTime > DateTime.Now && (lesson.Status == "Свободен слот" || lesson.Status == "Изчаква одобрение" || lesson.Status == "Одобрен");
                        var canComplete = !lesson.Completed && lesson.Status == "Одобрен" && !string.IsNullOrWhiteSpace(lesson.StudentName) && lesson.DateTime <= DateTime.Now;
                        var canCancel = !lesson.Completed && lesson.DateTime > DateTime.Now && (lesson.Status == "Свободен слот" || lesson.Status == "Изчаква одобрение" || lesson.Status == "Одобрен");

                        <tr>
                            <td>@lesson.DateTime.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@(string.IsNullOrWhiteSpace(lesson.StudentName) ? "—" : lesson.StudentName)</td>
                            <td>@lesson.CourseName</td>
                            <td><span class="status-pill @lesson.StatusCssClass">@lesson.Status</span></td>
                            <td>@lesson.Note</td>
                            <td class="text-end">
                                @if (canApproveReject)
                                {
                                    <form asp-action="Approve" asp-route-id="@lesson.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-success">Приеми</button>
                                    </form>
                                    <form asp-action="Reject" asp-route-id="@lesson.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-warning">Откажи</button>
                                    </form>
                                }

                                @if (canReschedule)
                                {
                                    <a asp-action="Reschedule" asp-route-id="@lesson.Id" class="btn btn-sm btn-outline-primary">Пренасрочи</a>
                                }

                                @if (canComplete)
                                {
                                    <a asp-action="Complete" asp-route-id="@lesson.Id" class="btn btn-sm btn-outline-success">Проведен</a>
                                }

                                @if (canCancel)
                                {
                                    <form asp-action="Cancel" asp-route-id="@lesson.Id" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button class="btn btn-sm btn-outline-danger">Отмени</button>
                                    </form>
                                }

                                @if (!canApproveReject && !canReschedule && !canComplete && !canCancel)
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <a class="btn btn-outline-secondary mt-3" asp-controller="Home" asp-action="Index">Назад към началната страница</a>
}
