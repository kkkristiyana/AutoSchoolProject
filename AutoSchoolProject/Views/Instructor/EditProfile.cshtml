@model AutoSchoolProject.ViewModels.Instructor.EditInstructorProfileViewModel
@{
    ViewData["Title"] = "Редакция на профил";
}

<form asp-action="EditProfile" method="post" enctype="multipart/form-data" class="card shadow-sm p-4">
    @Html.AntiForgeryToken()

    <div class="row g-4">
        <div class="col-md-6">
            <label asp-for="FirstName" class="form-label"></label>
            <input asp-for="FirstName" class="form-control" />
            <span asp-validation-for="FirstName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="LastName" class="form-label"></label>
            <input asp-for="LastName" class="form-control" />
            <span asp-validation-for="LastName" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="PhoneNumber" class="form-label"></label>
            <input asp-for="PhoneNumber" class="form-control" />
            <span asp-validation-for="PhoneNumber" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Категория</label>
            <input value="@Model.CourseName" class="form-control" readonly />
            <div class="form-text">Категорията се променя само от администратор.</div>
        </div>
        <div class="col-md-6">
            <label asp-for="CarModel" class="form-label"></label>
            <input asp-for="CarModel" class="form-control" />
            <span asp-validation-for="CarModel" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="ProfileImage" class="form-label"></label>
            <div class="file-picker d-flex align-items-center gap-3 flex-wrap">
                <input asp-for="ProfileImage" type="file" id="instructorProfileImage" class="d-none js-bulgarian-file-input" accept="image/*" />
                <label for="instructorProfileImage" class="btn btn-outline-secondary mb-0">Избери файл</label>
                <span class="small text-muted js-file-name">Няма избран файл</span>
            </div>
            <span asp-validation-for="ProfileImage" class="text-danger"></span>
            @if (!string.IsNullOrWhiteSpace(Model.CurrentProfileImagePath))
            {
                <img src="@Model.CurrentProfileImagePath" alt="Профилна снимка" class="mt-3" style="width:84px;height:84px;border-radius:50%;object-fit:cover;" />
            }
        </div>
        <div class="col-md-6">
            <label asp-for="CarImage" class="form-label"></label>
            <div class="file-picker d-flex align-items-center gap-3 flex-wrap">
                <input asp-for="CarImage" type="file" id="instructorCarImage" class="d-none js-bulgarian-file-input" accept="image/*" />
                <label for="instructorCarImage" class="btn btn-outline-secondary mb-0">Избери файл</label>
                <span class="small text-muted js-file-name">Няма избран файл</span>
            </div>
            <span asp-validation-for="CarImage" class="text-danger"></span>
            @if (!string.IsNullOrWhiteSpace(Model.CurrentCarImagePath))
            {
                <img src="@Model.CurrentCarImagePath" alt="Снимка на колата" class="mt-3" style="max-width:180px;border-radius:16px;object-fit:cover;" />
            }
        </div>
    </div>

    <div class="mt-4 d-flex flex-wrap gap-2">
        <button type="submit" class="btn btn-primary">Запази промените</button>
        <a asp-action="Profile" class="btn btn-outline-secondary">Назад</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
