@{
    ViewData["Title"] = "Начало";
}

<section class="home-hero">
    <div class="home-hero-grid">
        <div class="home-hero-copy">
            <span class="hero-kicker">Онлайн управление на автошкола</span>

            <h1 class="hero-title">
                <span class="hero-line hero-line--plain">Започни курса</span>
                <span class="hero-line hero-line--plain">си по</span>
                <span class="hero-line hero-line--accent">правилния</span>
                <span class="hero-line hero-line--accent">път.</span>
            </h1>

            <p>
                Виж категориите, условията и контактите на автошколата.
                За да изпратиш заявка за записване, първо си направи регистрация.
            </p>

            <div class="d-flex flex-wrap gap-2">
                <a class="btn btn-primary" asp-controller="Home" asp-action="CoursesInfoOnly">Курсове и цени</a>
                <a class="btn btn-warning" asp-area="Identity" asp-page="/Account/Register">Регистрация</a>
                <a class="btn btn-outline-secondary" asp-controller="Home" asp-action="ContactsViewerOnly">Контакти</a>
            </div>
        </div>

        <div class="home-hero-visual">
            <div class="placeholder-media">Място за основна снимка</div>
        </div>
    </div>
</section>

<section class="mb-5">
    <h2 class="home-section-title">Какво ще намериш тук</h2>
    <p class="home-section-subtitle">Подготвен старт за курсисти, инструктори и администрация.</p>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="home-service-card">
                <div class="placeholder-media">Снимка 1</div>
                <h5>Курсове</h5>
                <p>Подробна информация за категориите, цените и условията за обучение.</p>
                <a class="btn btn-outline-primary" asp-controller="Home" asp-action="CoursesInfoOnly">Преглед</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="home-service-card">
                <div class="placeholder-media">Снимка 2</div>
                <h5>Лесна регистрация</h5>
                <p>Създай профил и използвай същия имейл и парола през целия процес на обучение.</p>
                <a class="btn btn-outline-primary" asp-area="Identity" asp-page="/Account/Register">Създай профил</a>
            </div>
        </div>
        <div class="col-md-4">
            <div class="home-service-card">
                <div class="placeholder-media">Снимка 3</div>
                <h5>Практически часове</h5>
                <p>След одобрение ще можеш да избираш инструктор и свободни часове за практика.</p>
                <a class="btn btn-outline-primary" asp-area="Identity" asp-page="/Account/Login">Вход</a>
            </div>
        </div>
    </div>
</section>